# ============================================================================
# Pawbot — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env — it's in .gitignore.
#
# All variables use the PAWBOT_ prefix with double-underscore nesting.
# They map to config.json fields, e.g.:
#   PAWBOT_PROVIDERS__OPENROUTER__API_KEY → providers.openrouter.apiKey
# ============================================================================

# ── LLM Provider Keys (use ONE or more) ────────────────────────────
PAWBOT_PROVIDERS__OPENROUTER__API_KEY=
PAWBOT_PROVIDERS__ANTHROPIC__API_KEY=
PAWBOT_PROVIDERS__OPENAI__API_KEY=
PAWBOT_PROVIDERS__DEEPSEEK__API_KEY=
PAWBOT_PROVIDERS__GEMINI__API_KEY=
PAWBOT_PROVIDERS__GROQ__API_KEY=
PAWBOT_PROVIDERS__MOONSHOT__API_KEY=
PAWBOT_PROVIDERS__MINIMAX__API_KEY=

# ── Model ──────────────────────────────────────────────────────────
PAWBOT_AGENTS__DEFAULTS__MODEL=anthropic/claude-sonnet-4-5
PAWBOT_AGENTS__DEFAULTS__PROVIDER=auto

# ── Channels ───────────────────────────────────────────────────────
PAWBOT_CHANNELS__TELEGRAM__TOKEN=
PAWBOT_CHANNELS__TELEGRAM__ALLOW_FROM=[]
PAWBOT_CHANNELS__DISCORD__TOKEN=
PAWBOT_CHANNELS__DISCORD__ALLOW_FROM=[]
PAWBOT_CHANNELS__SLACK__BOT_TOKEN=
PAWBOT_CHANNELS__SLACK__APP_TOKEN=

# ── Tools ──────────────────────────────────────────────────────────
PAWBOT_TOOLS__WEB__SEARCH__API_KEY=
